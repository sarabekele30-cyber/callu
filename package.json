{
  "name": "callu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch server.ts --watch lib --watch app --ext ts,json,tsx --exec ts-node --project tsconfig.server.json server.ts",
    "build": "next build && tsc server.ts --outDir . --module commonjs --esModuleInterop --skipLibCheck --resolveJsonModule",
    "start": "node server.js",
    "lint": "eslint",
    "seed": "ts-node --project tsconfig.server.json seed.ts"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.17.15",
    "@types/youtube-player": "^5.5.11",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.34.0",
    "imagekit": "^5.2.0",
    "lenis": "^1.3.17",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.563.0",
    "mongoose": "^9.6.2",
    "next": "^16.1.6",
    "nodemailer": "^8.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-youtube": "^10.1.0",
    "resend": "^6.9.2",
    "simple-peer": "^9.11.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "styled-components": "^6.3.9",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/styled-components": "^5.1.36",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "nodemon": "^3.1.11",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
